# Normalize source text consistently across machines.
*.cpp text eol=crlf
*.h text eol=crlf
*.glsl text eol=crlf
*.vcxproj text eol=crlf
*.filters text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
*.ps1 text eol=crlf
*.gitignore text eol=crlf

# Wavefront OBJ assets are text, but should keep stable Windows newlines.
*.obj text eol=crlf

# Binary assets and libraries must never be line-ending normalized.
*.lib binary
*.png binary
*.jpg binary
*.wav binary
